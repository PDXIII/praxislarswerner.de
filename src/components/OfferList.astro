---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";

interface Offer {
  params: { slug: string };
  props: {
    name: string;
    info: string;
    image?: { url: string; description?: string };
  };
}

const { offers } = Astro.props as { offers: Offer[] };
---

<section class="container mx-auto px-4 mb-8">
  <SectionHeader title="Therapien" id="therapy" />
  <ul class="grid grid-cols-1 2xl:grid-cols-2 gap-6 mx-auto max-w-3xl">
    {offers.map((item, index) => (
      <li>
        <a class="group" href={`/angebot/${item.params.slug}`}>
          <article class="relative flex overflow-hidden group-hover:shadow-lg transition-all group-hover:scale-105" style="height: 200px">

            {item.props.image && (() => {
              const src = item.props.image.url.startsWith("//")
                ? `https:${item.props.image.url}`
                : item.props.image.url;
              return (
                <div class={`shrink-0 w-[200px] h-[200px] ${index % 2 !== 0 ? "order-2" : "order-1"}`}>
                  <Image
                    src={src}
                    alt={item.props.image.description || ""}
                    width={200}
                    height={200}
                    class="object-cover object-center w-full h-full"
                  />
                </div>
              );
            })()}

            <div class={`flex-1 bg-brand flex items-center px-6 ${index % 2 !== 0 ? "order-1 justify-end text-right" : "order-2 justify-start text-left"}`}>
              <h3
                class="text-xl sm:text-2xl text-white group-hover:underline underline-offset-4 font-smallCapsBold tracking-wider"
                set:html={item.props.name}
              />
            </div>

            <div class="absolute bg-white w-full h-full px-8 top-[200px] group-hover:top-0 z-10 opacity-0 group-hover:opacity-100 pt-8 transition-all text-left overflow-hidden flex flex-col justify-center">
              <h3 class="text-xl font-smallCapsBold tracking-wider text-brand">
                {item.props.name}
              </h3>
              <p class="text-gray-800 text-sm mt-2">{item.props.info}</p>
            </div>

          </article>
        </a>
      </li>
    ))}
  </ul>
</section>
