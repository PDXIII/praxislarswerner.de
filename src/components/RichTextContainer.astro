---
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";

interface Props {
  content: any;
  class?: string;
}

const { content, class: classList } = Astro.props;
const renderedHTML = documentToHtmlString(content);
---

<div
  set:html={renderedHTML}
  class={`mx-auto mt-16 prose prose-h2:text-3xl prose-h2:font-smallCaps prose-h2:text-brand prose-h2:tracking-wide prose-h2:text-center prose-h2:mt-16 prose-h2:mx-8 prose-h2:mb-8 ${classList || ""}`}
/>