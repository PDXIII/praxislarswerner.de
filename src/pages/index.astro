---
import Base from "../layouts/Base.astro";
import Slideshow from "../components/Slideshow.astro";
import TeamList from "../components/TeamList.astro";
import OfferList from "../components/OfferList.astro";
import FundstueckList from "../components/FundstueckList.astro";
import PartnerList from "../components/PartnerList.astro";
import Map from "../components/Map.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import RichTextContainer from "../components/RichTextContainer.astro";

import {
  getLandingPage,
  getTeamMembers,
  getOffers,
  getPartners,
  getConfigByID,
  getBookmarks,
} from "../lib/API";

import { cached } from "../lib/cached";
import { CONTENTFUL_IDS } from "../lib/constants";

// 🚀 Alle API-Aufrufe parallel und gecacht
const [landingPage, teamMembers, offers, partners, settings, fundstuecke] = await Promise.all([
  cached("landingPage", getLandingPage),
  cached("teamMembers", getTeamMembers),
  cached("offers", getOffers),
  cached("partners", getPartners),
  cached("settings", () => getConfigByID(CONTENTFUL_IDS.settings)),
  cached("bookmarks", getBookmarks),
]);

const data = (settings?.data ?? {}) as Record<string, any>;

// Metadaten für Base
const title = `${data.title} – ${data.subtitle}`;
const description = landingPage.props.info || data.subtitle;
const rawImage = landingPage.props.slideshowImages?.[0]?.fields?.file?.url ?? "";
const image = rawImage.startsWith("//") ? `https:${rawImage}` : rawImage;
const domain = data.domain ?? "";

---
<Base title={title} description={description} slug="" image={image} domain={domain} brand={`${data.prefix} ${data.owner}`}>
  <header class="w-screen h-screen relative">
    <Slideshow images={landingPage.props.slideshowImages} />
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 text-shadow-lg text-center">
      <p class="prefix lowercase text-xl font-smallCaps leading-none text-brand tracking-wider drop-shadow-lg" set:html={data.prefix} />
      <h1 class="title min-w-52 font-smallCapsBold text-2xl sm:text-4xl text-brand tracking-wider mb-2 drop-shadow-xl">
        <span class="border-brand px-4 sm:px-8 border-b-2">{data.owner}</span>
      </h1>
      <p class="subtitle font-primary text-lg sm:text-xl" set:html={data.subtitle} />
    </div>
  </header>

  <main>
    <RichTextContainer class="p-4 text-center" content={landingPage.props.introText} />

    <!-- Team -->
    <TeamList teamMembers={teamMembers} />

    <!-- Angebote -->
    <OfferList offers={offers} />

    <!-- Fundstücke -->
    {fundstuecke.length > 0 && (
      <FundstueckList items={fundstuecke} limit={3}>
        {landingPage.props.fundstueckeText && (
          <RichTextContainer slot="intro" class="px-4 text-center max-w-3xl mx-auto mb-10 mt-0" style="margin-top: 0;" content={landingPage.props.fundstueckeText} />
        )}
      </FundstueckList>
    )}

    <!-- Kontakt -->
    <section class="mb-8">
      <SectionHeader title="Kontakt" id="contact" />
      <Map id="map" data={data} />
      <RichTextContainer class="p-4 text-center" content={landingPage.props.contactText} />
      <ContactForm />
    </section>

    <!-- Partner -->
    <PartnerList partners={partners} />
  </main>
</Base>
